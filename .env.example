# Berimbau Pro — environment variables.
# Copy this file to .env (or .env.local) and fill in real values.
#
# All cloud features (auth, leaderboard, sync, payments, error tracking)
# are gated on these. The app runs offline-only when they're missing —
# practice + calibration + local stats keep working unchanged.

# Supabase project URL and the public anon key. From the Supabase
# dashboard → Project Settings → API. The anon key is safe to ship to
# the browser; row-level security is what actually protects data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry DSN for browser error reporting. Sentry → project → SDK setup.
# Optional; leave blank to disable.
VITE_SENTRY_DSN=

# Stripe publishable key (pk_test_... or pk_live_...). Stripe → Developers
# → API keys. Optional until you ship payments. The secret key lives on
# the server, never here.
VITE_STRIPE_PUBLISHABLE_KEY=
